{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitStory Labeled Commit Dataset",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["commit_id", "message", "phase", "urgency", "conflict"],
    "properties": {
      "commit_id": { "type": "string" },
      "message": { "type": "string" },
      "phase": {
        "type": "string",
        "enum": ["bugfix", "feature", "cleanup", "refactor"]
      },
      "urgency": {
        "type": "string",
        "enum": ["low", "medium", "high"]
      },
      "conflict": { "type": "boolean" },
      "timestamp": { "type": "string" },
      "author": { "type": "string" },
      "email": { "type": "string" },
      "files": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["path", "additions", "deletions", "status"],
          "properties": {
            "path": { "type": "string" },
            "additions": { "type": "integer" },
            "deletions": { "type": "integer" },
            "status": { "type": "string" }
          }
        }
      }
    },
    "additionalProperties": true
  }
}
